// https://w3c.github.io/performance-timeline/#performanceobserverentrylist-interface
[Exposed=(Window,Worker)]
interface PerformanceObserverEntryList {
    [NeedsCallerRealm] PerformanceEntryList getEntries();
    [NeedsCallerRealm] PerformanceEntryList getEntriesByType(DOMString type);
    [NeedsCallerRealm] PerformanceEntryList getEntriesByName(DOMString name, optional DOMString type);
};
