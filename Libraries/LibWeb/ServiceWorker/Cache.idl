// https://w3c.github.io/ServiceWorker/#cache-interface
[SecureContext, Exposed=(Window,Worker)]
interface Cache {
    [NeedsCallerRealm, NewObject] Promise<(Response or undefined)> match(RequestInfo request, optional CacheQueryOptions options = {});
    [NeedsCallerRealm, NewObject] Promise<FrozenArray<Response>> matchAll(optional RequestInfo request, optional CacheQueryOptions options = {});
    [NeedsCallerRealm, NewObject] Promise<undefined> add(RequestInfo request);
    [NeedsCallerRealm, NewObject] Promise<undefined> addAll(sequence<RequestInfo> requests);
    [NeedsCallerRealm, NewObject] Promise<undefined> put(RequestInfo request, Response response);
    [NeedsCallerRealm, NewObject] Promise<boolean> delete(RequestInfo request, optional CacheQueryOptions options = {});
    [NeedsCallerRealm, NewObject] Promise<FrozenArray<Request>> keys(optional RequestInfo request, optional CacheQueryOptions options = {});
};

dictionary CacheQueryOptions {
    boolean ignoreSearch = false;
    boolean ignoreMethod = false;
    boolean ignoreVary = false;
};
