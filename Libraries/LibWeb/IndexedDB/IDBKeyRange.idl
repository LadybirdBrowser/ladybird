    [ImplementedAs=key_range_upper, ImplementedInBindings, NeedsCallerRealmForGetter] readonly attribute any upper;
    readonly attribute boolean lowerOpen;
    readonly attribute boolean upperOpen;

    [ImplementedInBindings, NeedsCallerRealm, NewObject] static IDBKeyRange only(any value);
