    [ImplementedInBindings, NeedsCallerRealm, NewObject] static IDBKeyRange bound(any lower, any upper, optional boolean lowerOpen = false, optional boolean upperOpen = false);

    [ImplementedInBindings, NeedsCallerRealm] boolean includes(any key);
};
