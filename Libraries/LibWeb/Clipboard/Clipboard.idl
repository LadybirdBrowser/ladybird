typedef sequence<ClipboardItem> ClipboardItems;

// https://w3c.github.io/clipboard-apis/#clipboard
[SecureContext, Exposed=Window]
interface Clipboard : EventTarget {
    [NeedsThisObjectRealm] Promise<ClipboardItems> read(optional ClipboardUnsanitizedFormats formats = {});
    [NeedsThisObjectRealm] Promise<DOMString> readText();
    [NeedsThisObjectRealm] Promise<undefined> write(ClipboardItems data);
    [NeedsThisObjectRealm] Promise<undefined> writeText(DOMString data);
};

dictionary ClipboardUnsanitizedFormats {
    sequence<DOMString> unsanitized;
};
