// https://w3c.github.io/FileAPI/#FileReaderSync
[Exposed=(DedicatedWorker,SharedWorker)]
interface FileReaderSync {
    constructor();
    // Synchronously return strings

    [NeedsCallerRealm] ArrayBuffer readAsArrayBuffer(Blob blob);
    [NeedsCallerRealm] DOMString readAsText(Blob blob, optional DOMString encoding);
    [NeedsCallerRealm] DOMString readAsBinaryString(Blob blob);
    [NeedsCallerRealm] DOMString readAsDataURL(Blob blob);
};
