// https://streams.spec.whatwg.org/#writablestream
    [Exposed=*,
    Transferable]
interface WritableStream {
    constructor(optional object underlyingSink, optional QueuingStrategy strategy = {});

    readonly attribute boolean locked;

    [NeedsThisObjectRealm] Promise<undefined> abort(optional any reason);
    [NeedsThisObjectRealm] Promise<undefined> close();
    [NeedsThisObjectRealm] WritableStreamDefaultWriter getWriter();
};
