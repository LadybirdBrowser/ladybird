// https://fetch.spec.whatwg.org/#body
interface mixin Body {
    readonly attribute ReadableStream? body;
    readonly attribute boolean bodyUsed;
    [NeedsCallerRealm, NewObject] Promise<ArrayBuffer> arrayBuffer();
    [NeedsCallerRealm, NewObject] Promise<Blob> blob();
    [NeedsCallerRealm, NewObject] Promise<Uint8Array> bytes();
    [NeedsCallerRealm, NewObject] Promise<FormData> formData();
    [NeedsCallerRealm, NewObject] Promise<any> json();
    [NeedsCallerRealm, NewObject] Promise<USVString> text();
};
