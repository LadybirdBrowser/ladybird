<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/sheetIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="@null"
            android:tint="@color/ladybird_accent"
            tools:src="@drawable/ic_bookmark" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ladybird_on_surface"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Bookmarks" />

            <TextView
                android:id="@+id/sheetSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ladybird_on_surface_muted"
                android:textSize="12sp"
                tools:text="3 saved" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sheetActionButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/ladybird_accent"
            tools:text="Clear" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/ladybird_divider" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sheetList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="12dp" />

        <LinearLayout
            android:id="@+id/sheetEmptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:alpha="0.35"
                android:contentDescription="@null"
                android:src="@drawable/ic_globe_full"
                android:tint="@color/ladybird_on_surface_muted" />

            <TextView
                android:id="@+id/sheetEmptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/ladybird_on_surface_muted"
                android:textSize="14sp"
                tools:text="No bookmarks yet" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
