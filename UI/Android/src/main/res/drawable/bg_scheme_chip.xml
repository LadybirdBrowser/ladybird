<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/ladybird_accent" />
            <corners android:radius="999dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ladybird_surface_variant" />
            <corners android:radius="999dp" />
            <stroke android:width="1dp" android:color="@color/ladybird_outline_soft" />
        </shape>
    </item>
</selector>
