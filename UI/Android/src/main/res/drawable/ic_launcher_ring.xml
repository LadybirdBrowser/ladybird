    <path android:pathData="M83.9,24.1 L80.6,27.4" android:strokeColor="#FFFF1FBF" android:strokeWidth="1.1" android:strokeLineCap="round" />
    <path android:pathData="M83.9,83.9 L80.6,80.6" android:strokeColor="#FFFF1FBF" android:strokeWidth="1.1" android:strokeLineCap="round" />
    <path android:pathData="M24.1,83.9 L27.4,80.6" android:strokeColor="#FFFF1FBF" android:strokeWidth="1.1" android:strokeLineCap="round" />
    <path android:pathData="M24.1,24.1 L27.4,27.4" android:strokeColor="#FFFF1FBF" android:strokeWidth="1.1" android:strokeLineCap="round" />

