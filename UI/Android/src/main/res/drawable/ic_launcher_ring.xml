    <path
        android:pathData="M84,72 m-2.4,0 a2.4,3.2 0 1,0 4.8,0 a2.4,3.2 0 1,0 -4.8,0"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="0.9"
        android:fillColor="#00000000" />
    <path
        android:pathData="M84,72 L86.4,72"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="0.9"
        android:strokeLineCap="round" />
